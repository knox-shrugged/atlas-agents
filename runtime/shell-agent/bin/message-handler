#!/usr/bin/env bash
# Drains pending Supabase messages for this agent and executes them.
# AGENT_EXEC=claude → claude -p; default → bash -c
# Requires: curl, jq (or node as fallback for JSON encoding)

set -euo pipefail

if [ -z "${SUPABASE_URL:-}" ] || [ -z "${SUPABASE_ANON_KEY:-}" ] || [ -z "${AGENT_ID:-}" ]; then
  echo "[message-handler] SUPABASE_URL, SUPABASE_ANON_KEY or AGENT_ID not set — skipping"
  exit 0
fi

AUTH_HEADER="Authorization: Bearer ${SUPABASE_ANON_KEY}"
API_HEADER="apikey: ${SUPABASE_ANON_KEY}"
AGENT_EXEC="${AGENT_EXEC:-bash}"

json_encode() {
  if command -v jq >/dev/null 2>&1; then
    jq -Rs .
  elif command -v node >/dev/null 2>&1; then
    node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>process.stdout.write(JSON.stringify(d)));"
  else
    python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))"
  fi
}

claim_and_run() {
  local msg_id="$1"
  local payload="$2"
  echo "[message-handler] processing message $msg_id"

  curl -sf -X PATCH \
    "${SUPABASE_URL}/rest/v1/messages?id=eq.${msg_id}" \
    -H "$AUTH_HEADER" -H "$API_HEADER" \
    -H "Content-Type: application/json" \
    -d '{"status":"processing"}' > /dev/null

  if [ "$AGENT_EXEC" = "claude" ]; then
    result=$(claude -p "$payload" --model claude-sonnet-4-5 2>&1) || result="error: exit $?"
  else
    result=$(bash -c "$payload" 2>&1) || result="error: exit $?"
  fi

  result_json=$(printf '%s' "$result" | json_encode)
  curl -sf -X PATCH \
    "${SUPABASE_URL}/rest/v1/messages?id=eq.${msg_id}" \
    -H "$AUTH_HEADER" -H "$API_HEADER" \
    -H "Content-Type: application/json" \
    -d "{\"status\":\"done\",\"result\":${result_json}}" > /dev/null

  echo "[message-handler] done $msg_id"
}

poll_once() {
  local pending
  pending=$(curl -sf \
    "${SUPABASE_URL}/rest/v1/messages?to_agent_id=eq.${AGENT_ID}&status=eq.pending&order=created_at.asc" \
    -H "$AUTH_HEADER" -H "$API_HEADER") || return 0

  if command -v jq >/dev/null 2>&1; then
    echo "$pending" | jq -r '.[] | .id + "\t" + .payload'
  elif command -v node >/dev/null 2>&1; then
    echo "$pending" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>JSON.parse(d).forEach(m=>console.log(m.id+'\t'+m.payload)));"
  fi | while IFS=$'\t' read -r id payload; do
    [ -n "$id" ] && claim_and_run "$id" "$payload"
  done
}

echo "[message-handler] started for agent $AGENT_ID (exec=$AGENT_EXEC)"
poll_once

while true; do
  sleep 5
  poll_once
done
