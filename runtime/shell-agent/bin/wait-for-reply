#!/usr/bin/env bash
# Poll a message until status = done, then print the result to stdout.
#
# Usage:
#   wait-for-reply <message_id> [timeout_seconds]
#
# Default timeout: 120s. Exits 1 on timeout.
# Env required: SUPABASE_URL, SUPABASE_ANON_KEY

set -euo pipefail

MSG_ID="${1:-}"
TIMEOUT="${2:-120}"

if [ -z "$MSG_ID" ]; then
  echo "Usage: wait-for-reply <message_id> [timeout_seconds]" >&2
  exit 1
fi

if [ -z "${SUPABASE_URL:-}" ] || [ -z "${SUPABASE_ANON_KEY:-}" ]; then
  echo "wait-for-reply: SUPABASE_URL or SUPABASE_ANON_KEY not set" >&2
  exit 1
fi

elapsed=0
while [ "$elapsed" -lt "$TIMEOUT" ]; do
  row=$(curl -sf \
    "${SUPABASE_URL}/rest/v1/messages?id=eq.${MSG_ID}&select=status,result" \
    -H "apikey: ${SUPABASE_ANON_KEY}" \
    -H "Authorization: Bearer ${SUPABASE_ANON_KEY}")

  status=$(echo "$row" | jq -r '.[0].status')

  if [ "$status" = "done" ]; then
    echo "$row" | jq -r '.[0].result // ""'
    exit 0
  fi

  sleep 2
  elapsed=$((elapsed + 2))
done

echo "wait-for-reply: timeout after ${TIMEOUT}s waiting for message ${MSG_ID}" >&2
exit 1
