#!/usr/bin/env bash
# Registers this Fly machine in Supabase agent registry on startup.
# Writes the assigned agent UUID to /data/agent_id for message-handler to consume.
# Requires: curl, jq (or node as fallback)

set -euo pipefail

if [ -z "${SUPABASE_URL:-}" ] || [ -z "${SUPABASE_ANON_KEY:-}" ]; then
  echo "[agent-register] SUPABASE_URL or SUPABASE_ANON_KEY not set — skipping"
  exit 0
fi

APP_NAME="${FLY_APP_NAME:-unknown}"
MACHINE_ID="${FLY_MACHINE_ID:-unknown}"
REGION="${FLY_REGION:-unknown}"
KIND="${AGENT_KIND:-shell-agent}"

AUTH_HEADER="Authorization: Bearer ${SUPABASE_ANON_KEY}"
API_HEADER="apikey: ${SUPABASE_ANON_KEY}"

result=$(curl -sf -X POST \
  "${SUPABASE_URL}/rest/v1/agents?on_conflict=fly_app_name" \
  -H "$AUTH_HEADER" -H "$API_HEADER" \
  -H "Content-Type: application/json" \
  -H "Prefer: return=representation,resolution=merge-duplicates" \
  -d "{\"fly_app_name\":\"${APP_NAME}\",\"fly_machine_id\":\"${MACHINE_ID}\",\"fly_region\":\"${REGION}\",\"status\":\"running\",\"kind\":\"${KIND}\"}" 2>&1) || {
  echo "[agent-register] curl failed"
  exit 0
}

if command -v jq >/dev/null 2>&1; then
  AGENT_ID=$(echo "$result" | jq -r '(if type == "array" then .[0] else . end).id // empty')
elif command -v node >/dev/null 2>&1; then
  AGENT_ID=$(echo "$result" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const a=JSON.parse(d);console.log((Array.isArray(a)?a[0]:a)?.id||'');}catch{}});")
else
  AGENT_ID=$(echo "$result" | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
fi

if [ -n "$AGENT_ID" ]; then
  echo "$AGENT_ID" > /data/agent_id
  echo "[agent-register] registered as $AGENT_ID (app=$APP_NAME machine=$MACHINE_ID)"
else
  echo "[agent-register] registration failed: $result"
fi
