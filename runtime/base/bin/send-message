#!/usr/bin/env bash
# Send a message to another agent via the Supabase messages table.
# Prints the new message ID to stdout.
#
# Usage:
#   send-message <to_agent_id> <payload>
#
# Env required: SUPABASE_URL, SUPABASE_ANON_KEY, AGENT_ID (set as from_agent_id)

set -euo pipefail

TO_AGENT_ID="${1:-}"
PAYLOAD="${2:-}"

if [ -z "$TO_AGENT_ID" ] || [ -z "$PAYLOAD" ]; then
  echo "Usage: send-message <to_agent_id> <payload>" >&2
  exit 1
fi

if [ -z "${SUPABASE_URL:-}" ] || [ -z "${SUPABASE_ANON_KEY:-}" ]; then
  echo "send-message: SUPABASE_URL or SUPABASE_ANON_KEY not set" >&2
  exit 1
fi

FROM_AGENT_ID="${AGENT_ID:-}"

payload_json=$(printf '%s' "$PAYLOAD" | jq -Rs .)

body="{\"to_agent_id\":\"$TO_AGENT_ID\",\"payload\":$payload_json,\"status\":\"pending\""
[ -n "$FROM_AGENT_ID" ] && body="$body,\"from_agent_id\":\"$FROM_AGENT_ID\""
body="$body}"

result=$(curl -sf -X POST \
  "${SUPABASE_URL}/rest/v1/messages" \
  -H "apikey: ${SUPABASE_ANON_KEY}" \
  -H "Authorization: Bearer ${SUPABASE_ANON_KEY}" \
  -H "Content-Type: application/json" \
  -H "Prefer: return=representation" \
  -d "$body")

echo "$result" | jq -r '.[0].id // .[].id'
