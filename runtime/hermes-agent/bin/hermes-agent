#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace

    # Bake model config if not already set (survives across push-runtime updates)
    HERMES_CFG=/root/.hermes/config.yaml
    if [ ! -f "$HERMES_CFG" ] || ! grep -q "^model:" "$HERMES_CFG" 2>/dev/null; then
      mkdir -p /root/.hermes
      cat > "$HERMES_CFG" <<'CFG'
model: google/gemini-2.5-flash
provider: openrouter
CFG
    fi

    cd /data/workspace

    cat <<BANNER
AtlasLives hermes-agent
Workspace: /data/workspace
Provider:  OpenRouter / gemini-2.5-flash
BANNER

    exec hermes --provider openrouter -m google/gemini-2.5-flash
    ;;
  *)
    echo "Unknown hermes-agent command: $command" >&2
    exit 64
    ;;
esac
