#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace
    mkdir -p /data/goose

    # Persist goose session data on the volume
    export XDG_CONFIG_HOME=/data/goose

    # Copy baked config to volume location if not already there
    if [ ! -f /data/goose/goose/config.yaml ]; then
      mkdir -p /data/goose/goose
      cp /root/.config/goose/config.yaml /data/goose/goose/config.yaml
    fi

    cd /data/workspace
    printf '%s goose-agent start pid=%s workspace=/data/workspace\n' "$(date -Iseconds)" "$$" >> /data/agent.log

    MODEL="${GOOSE_MODEL:-google/gemini-2.5-flash}"

    cat <<BANNER
AtlasLives goose-agent
Workspace: /data/workspace
Provider:  OpenRouter ($MODEL)
BANNER

    exec goose session
    ;;
  *)
    echo "Unknown goose-agent command: $command" >&2
    exit 64
    ;;
esac
