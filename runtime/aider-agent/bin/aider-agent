#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace
    cd /data/workspace
    printf '%s aider-agent start pid=%s workspace=/data/workspace\n' "$(date -Iseconds)" "$$" >> /data/agent.log

    MODEL="${AIDER_MODEL:-openrouter/qwen/qwen-2.5-coder-32b-instruct}"

    cat <<BANNER
AtlasLives aider-agent
Workspace: /data/workspace
Model:     $MODEL via OpenRouter
BANNER

    # Use --no-git when there's no repo so aider doesn't prompt to create one
    if git -C /data/workspace rev-parse --git-dir >/dev/null 2>&1; then
      exec aider --model "$MODEL" --no-check-update
    else
      exec aider --model "$MODEL" --no-git --no-check-update
    fi
    ;;
  *)
    echo "Unknown aider-agent command: $command" >&2
    exit 64
    ;;
esac
