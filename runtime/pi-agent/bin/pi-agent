#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace
    mkdir -p /data/pi

    # Persist pi session data on the volume
    export XDG_DATA_HOME=/data/pi

    cd /data/workspace
    {
      printf '%s pi-agent start pid=%s workspace=/data/workspace\n' "$(date -Iseconds)" "$$"
    } >> /data/agent.log

    cat <<'BANNER'
AtlasLives pi-agent
Workspace: /data/workspace
Provider:  OpenRouter (google/gemini-2.5-flash)
BANNER

    # Wire up Composio MCP server if API key is available
    if [ -n "${COMPOSIO_API_KEY:-}" ]; then
      node -e "
const fs = require('fs');
const path = '/root/.pi/agent/settings.json';
let c = {};
try { c = JSON.parse(fs.readFileSync(path, 'utf8')); } catch {}
if (!c.mcp) c.mcp = {};
c.mcp.composio = {
  type: 'remote',
  url: 'https://backend.composio.dev/tool_router/' + process.env.COMPOSIO_API_KEY + '/mcp',
  enabled: true
};
fs.writeFileSync(path, JSON.stringify(c, null, 2));
"
    fi

    exec pi --provider openrouter --model google/gemini-2.5-flash
    ;;
  *)
    echo "Unknown pi-agent command: $command" >&2
    exit 64
    ;;
esac
