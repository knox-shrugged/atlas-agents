#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace

    cd /data/workspace
    {
      printf '%s claude-agent start pid=%s workspace=/data/workspace\n' "$(date -Iseconds)" "$$"
    } >> /data/agent.log

    cat <<'BANNER'
AtlasLives claude-agent
Workspace: /data/workspace
Provider:  OpenRouter
BANNER

    # Pre-approve the runtime OpenRouter key so Claude Code skips the API key dialog
    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
      ANTHROPIC_KEY_SUFFIX="${ANTHROPIC_API_KEY: -20}" node -e "
const fs=require('fs'), os=require('os');
const p=os.homedir()+'/.claude.json';
let c={};
try{c=JSON.parse(fs.readFileSync(p,'utf8'));}catch{}
if(!c.customApiKeyResponses){c.customApiKeyResponses={approved:[],rejected:[]};}
const s=process.env.ANTHROPIC_KEY_SUFFIX;
if(s&&!c.customApiKeyResponses.approved.includes(s)){c.customApiKeyResponses.approved.push(s);}
fs.writeFileSync(p,JSON.stringify(c,null,2));
"
    fi

    SYSTEM_PROMPT=$(cat <<'SYSTEM'
You are an AtlasLives coordinator agent running on a Fly.io machine.
You can execute shell commands directly and dispatch work to other agents.

## Your agent ID
Your agent ID is in the file /data/agent_id. Read it when you need to identify yourself.

## Dispatching work to other agents

You have three scripts available in /usr/local/bin:

**agent-lookup <kind> [--first]**
Find other registered agents by kind. Returns agent IDs (one per line).
Kinds: shell-agent, claude-agent
Example: agent-lookup shell-agent --first

**send-message <to_agent_id> <payload>**
Send a task to another agent. Returns the message ID.
The payload is executed as a bash command on shell-agents, or as a prompt on claude-agents.
Example: send-message <id> "echo hello && date"

**wait-for-reply <message_id> [timeout_seconds]**
Block until the agent finishes and return its result. Default timeout: 120s.
Example: wait-for-reply <msg_id> 60

## Typical coordination pattern
```bash
# 1. Find an available shell agent
shell_id=$(agent-lookup shell-agent --first)

# 2. Dispatch a task
msg_id=$(send-message "$shell_id" "df -h && free -m")

# 3. Wait for the result
result=$(wait-for-reply "$msg_id" 30)
echo "$result"
```

## Guidelines
- Use shell-agents for file system work, git operations, running scripts
- Use claude-agents for analysis, summarization, writing
- Always wait-for-reply before using a subtask's output
- You can fan out multiple send-message calls then collect results in parallel
- Your workspace is /data/workspace — git repos go here
SYSTEM
)
    exec claude --model claude-sonnet-4-5 --system "$SYSTEM_PROMPT"
    ;;
  *)
    echo "Unknown claude-agent command: $command" >&2
    exit 64
    ;;
esac
