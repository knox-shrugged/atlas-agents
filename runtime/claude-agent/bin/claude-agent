#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace

    cd /data/workspace
    {
      printf '%s claude-agent start pid=%s workspace=/data/workspace\n' "$(date -Iseconds)" "$$"
    } >> /data/agent.log

    cat <<'BANNER'
AtlasLives claude-agent
Workspace: /data/workspace
Provider:  OpenRouter
BANNER

    # Pre-approve the runtime OpenRouter key so Claude Code skips the API key dialog
    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
      ANTHROPIC_KEY_SUFFIX="${ANTHROPIC_API_KEY: -20}" node -e "
const fs=require('fs'), os=require('os');
const p=os.homedir()+'/.claude.json';
let c={};
try{c=JSON.parse(fs.readFileSync(p,'utf8'));}catch{}
if(!c.customApiKeyResponses){c.customApiKeyResponses={approved:[],rejected:[]};}
const s=process.env.ANTHROPIC_KEY_SUFFIX;
if(s&&!c.customApiKeyResponses.approved.includes(s)){c.customApiKeyResponses.approved.push(s);}
fs.writeFileSync(p,JSON.stringify(c,null,2));
"
    fi

    # Wire up Composio MCP server if API key is available
    if [ -n "${COMPOSIO_API_KEY:-}" ]; then
      node -e "
const fs=require('fs'),os=require('os');
const p=os.homedir()+'/.claude.json';
let c={};
try{c=JSON.parse(fs.readFileSync(p,'utf8'));}catch{}
if(!c.mcpServers){c.mcpServers={};}
c.mcpServers.composio={
  command:'npx',
  args:['-y','@composio/mcp@latest','start','--composio-api-key',process.env.COMPOSIO_API_KEY,'--entity-id',process.env.COMPOSIO_ENTITY_ID||'default'],
  type:'stdio'
};
fs.writeFileSync(p,JSON.stringify(c,null,2));
"
    fi

    COMPOSIO_LINE=""
    if [ -n "${COMPOSIO_API_KEY:-}" ]; then
      COMPOSIO_LINE="You also have access to the **composio** MCP server which gives you OAuth-connected tools (GitHub, Gmail, Linear, Notion, Slack, etc.) for the workspace owner."
    fi

    SYSTEM_PROMPT=$(cat <<SYSTEM
You are an AtlasLives coordinator agent running on a Fly.io machine.
You can execute shell commands directly and delegate work to other agents.

Your agent ID is in /data/agent_id. Your workspace is /data/workspace.

You have access to the **atlas** MCP server which provides three tools:
- **agent_lookup** — find other registered agents by kind (claude-agent, opencode-agent)
- **send_message** — dispatch a task to another agent, returns a message ID
- **wait_for_reply** — block until the agent completes and return its result

Payloads sent to claude-agent or opencode-agent are treated as natural-language prompts.

$COMPOSIO_LINE

## Guidelines
- Use opencode-agents for large code generation tasks (Gemini has a larger context window)
- Use claude-agents for reasoning, analysis, and coordination
- Fan out multiple send_message calls then collect results before proceeding
- Always wait_for_reply before using a subtask's output
SYSTEM
)
    exec claude --model claude-sonnet-4-5 --append-system-prompt "$SYSTEM_PROMPT"
    ;;
  *)
    echo "Unknown claude-agent command: $command" >&2
    exit 64
    ;;
esac
