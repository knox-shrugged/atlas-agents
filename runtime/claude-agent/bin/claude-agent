#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace

    cd /data/workspace
    {
      printf '%s claude-agent start pid=%s workspace=/data/workspace\n' "$(date -Iseconds)" "$$"
    } >> /data/agent.log

    cat <<'BANNER'
AtlasLives claude-agent
Workspace: /data/workspace
Provider:  OpenRouter
BANNER

    # Pre-approve the runtime OpenRouter key so Claude Code skips the API key dialog
    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
      ANTHROPIC_KEY_SUFFIX="${ANTHROPIC_API_KEY: -20}" node -e "
const fs=require('fs'), os=require('os');
const p=os.homedir()+'/.claude.json';
let c={};
try{c=JSON.parse(fs.readFileSync(p,'utf8'));}catch{}
if(!c.customApiKeyResponses){c.customApiKeyResponses={approved:[],rejected:[]};}
const s=process.env.ANTHROPIC_KEY_SUFFIX;
if(s&&!c.customApiKeyResponses.approved.includes(s)){c.customApiKeyResponses.approved.push(s);}
fs.writeFileSync(p,JSON.stringify(c,null,2));
"
    fi

    exec claude --model claude-sonnet-4-5
    ;;
  *)
    echo "Unknown claude-agent command: $command" >&2
    exit 64
    ;;
esac
