#!/usr/bin/env bash
set -euo pipefail

command="${1:-start}"

case "$command" in
  start)
    if [ -n "${ATLAS_GIT_USER_NAME:-}" ]; then
      git config --global user.name "$ATLAS_GIT_USER_NAME"
    fi
    if [ -n "${ATLAS_GIT_USER_EMAIL:-}" ]; then
      git config --global user.email "$ATLAS_GIT_USER_EMAIL"
    fi

    if [ -n "${ATLAS_GITHUB_REPO:-}" ] && [ ! -d "/data/workspace/.git" ]; then
      echo "Cloning $ATLAS_GITHUB_REPO..."
      rm -rf /data/workspace
      if ! git clone "https://${ATLAS_GITHUB_TOKEN}@github.com/${ATLAS_GITHUB_REPO}.git" /data/workspace 2>&1; then
        echo "WARNING: clone failed — starting with empty workspace"
      fi
    fi

    mkdir -p /data/workspace

    # Persist OpenHands config/state to Fly volume across suspend/resume
    mkdir -p /data/.openhands
    if [ ! -L "$HOME/.openhands" ]; then
      rm -rf "$HOME/.openhands"
      ln -s /data/.openhands "$HOME/.openhands"
    fi

    cd /data/workspace

    cat <<BANNER
AtlasLives openhands-agent
Workspace: /data/workspace
Provider:  OpenRouter
Model:     anthropic/claude-sonnet-4-5
Note:      No Docker sandbox — code runs directly on this machine
BANNER

    # --override-with-envs reads LLM_* env vars at startup (not persisted to config)
    export LLM_BASE_URL="https://openrouter.ai/api/v1"
    export LLM_API_KEY="${OPENROUTER_API_KEY:-}"
    export LLM_MODEL="anthropic/claude-sonnet-4-5"
    exec /root/.local/share/uv/tools/openhands/bin/openhands --override-with-envs
    ;;
  *)
    echo "Unknown openhands-agent command: $command" >&2
    exit 64
    ;;
esac
